# Backend environment — copy to .env and fill in. NEVER commit the real .env.
# This is the PRODUCTION config. For local SQLite dev, use `.env.local` instead
# (see .env.local.example) — it overrides this file when present.
ENVIRONMENT=production

# Supabase session pooler URL (see rt-basic-app-deploy skill). Keep the
# `+psycopg` scheme (psycopg v3; plain postgresql:// loads psycopg2 which isn't
# installed). When pasting the Supabase pooler string, fill in the `<region>`
# placeholder (this project: aws-1-ap-northeast-1) and strip any trailing space
# in the password.
DATABASE_URL=postgresql+psycopg://postgres.<ref>:<password>@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# Frontend origin(s) allowed by CORS (comma-separated).
CORS_ORIGINS=http://localhost:3000

# Supabase auth (owner/admin sign-in). No JWT secret needed — the backend
# validates the admin's access token by introspection (calls Supabase's
# /auth/v1/user). Both values are public: the project URL and the publishable
# (or anon) key, which is sent as the `apikey` header.
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Comma-separated allowlist of admin emails. Only these (matched against the
# email Supabase returns for the token) may use the /admin dashboard.
ADMIN_EMAILS=you@example.com



# Transactional email (Resend). When BOTH are set, emails go out for real;
# otherwise they only land in the dev outbox + server log. EMAIL_FROM must be
# a sender verified in Resend, e.g. "Invites <invites@yourdomain.com>".
RESEND_API_KEY=
EMAIL_FROM=

# Guest-API rate limiting (per instance, per IP, per minute). Defaults: on in
# production only, reads 120/min, writes 30/min. Uncomment to override.
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_GUEST_READS_PER_MINUTE=120
# RATE_LIMIT_GUEST_WRITES_PER_MINUTE=30

# Shared secret for the internal cron endpoints (/api/internal/cron/*), which
# Vercel cron calls with `Authorization: Bearer $CRON_SECRET`. Empty = those
# routes 404 (feature off). Generate a long random string.
CRON_SECRET=

# Observability. Error tracking activates only when SENTRY_DSN is set;
# LOG_LEVEL tunes server logging (default INFO).
SENTRY_DSN=
# LOG_LEVEL=INFO

# --- AI creation wizard (Phase 8, docs/AI_WIZARD_PLAN.md "API keys" table) ---
#
# LIVE CALLS — the master switch. false = this process makes NO AI call at all,
# whatever keys are set below: text runs on the offline `fake` adapter, media
# transcription is refused, illustrations are skipped, venues keep the couple's
# own words. Every one of those is a graceful degrade, not an error. Production
# wants it on; the browser smokes want it off (see .env.local.example).
# AI_LIVE_CALLS=true
#
# With live calls on, each capability can still be switched off on its own —
# useful to stop paying per image while keeping text drafting. A `true` here can
# never re-enable something AI_LIVE_CALLS=false has switched off.
# AI_LIVE_TEXT=true
# AI_LIVE_IMAGES=true         # ~$0.067 per image (Nano Banana 2)
# AI_LIVE_TRANSCRIBE=true
# AI_LIVE_PLACES=true
#
# DEV ONLY (refused when ENVIRONMENT=production): paint placeholder art instead
# of calling the image model, so the staged story wizard can be demoed and
# browser-smoked without spend. A real wedding must never get a placeholder.
# AI_FAKE_IMAGES=false

# Text model (extraction/drafting/grounding/glyph). Create the Anthropic key in
# a SEPARATE workspace at console.anthropic.com so its spend is capped
# independently. Provider is config, not code — and the MODEL FOLLOWS THE
# PROVIDER (see AI_MODEL_* below), so this one line is a complete switch.
# A provider swap should pass the golden-set eval (8.1c) before production.
# AI_TEXT_PROVIDER=anthropic    # anthropic | openai | fake
# AI_TEXT_EFFORT=high           # low | medium | high
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Gemini: audio/PDF/image transcription + story-beat images.
# MUST be a key from a BILLING-ENABLED Google project — free-tier AI Studio
# input may be used for product improvement, and that would be guest PII.
# Empty = media uploads are refused with a clean error and story beats stay
# text-only; text-only runs still work end to end.
GEMINI_API_KEY=

# Google Places (optional): resolves the extracted venue NAME to a real
# address/map URL, removing address hallucination. Restrict the key + set a
# billing cap in the Google Cloud console. Empty = the proposal keeps the
# couple's own words and no address is invented.
GOOGLE_PLACES_API_KEY=

# MODEL IDS — one per provider, because they churn and a swap must never need a
# code change. AI_TEXT_PROVIDER picks which of these two is used; you do not set
# the model and the provider separately (that pairing used to be possible to get
# wrong). Gemini ids confirmed against ai.google.dev/gemini-api/docs/models
# 2026-07-12. Defaults:
# AI_MODEL_ANTHROPIC=claude-opus-4-8
# AI_MODEL_OPENAI=gpt-5.1
# GEMINI_TRANSCRIBE_MODEL=gemini-3.5-flash
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image     # "Nano Banana 2", per-image price
#
# Pin an exact snapshot id, overriding the provider default above. Rarely needed.
# AI_TEXT_MODEL=

# LOCAL DEV overrides — copy to `.env.local` (gitignored) to run against a local
# SQLite database instead of production Supabase. This file OVERRIDES `.env`, so
# its presence = local mode; delete `.env.local` to go back to production.
#
#   cp .env.local.example .env.local      # -> local SQLite
#   python -m scripts.dev_setup           # create + seed the local DB
#   uvicorn app.main:app --reload         # /health should report "db": "sqlite"
#   rm .env.local                         # -> back to production Supabase

ENVIRONMENT=local

# Local SQLite file (created in the backend/ working dir). No server to run.
DATABASE_URL=sqlite:///./dev.db

# The Next.js dev origin.
CORS_ORIGINS=http://localhost:3000

# LOCAL-ONLY admin login for /admin. Set the SAME value as the frontend's
# NEXT_PUBLIC_DEV_ADMIN_TOKEN. Ignored when ENVIRONMENT=production (there only a
# real Supabase JWT + ADMIN_EMAILS allowlist is accepted).
DEV_ADMIN_TOKEN=local-dev-admin-token-change-me

# --- AI: does this box spend money? -----------------------------------------
# THE master switch. false = no AI call leaves this process, whatever keys are
# sitting in .env: text drafting runs on the offline `fake` adapter (canned
# responses — the full pipeline still works end to end), transcription refuses
# media, illustrations are skipped (beats stay text-only), and venues keep the
# couple's own words. Run the Puppeteer smokes with this OFF.
AI_LIVE_CALLS=false

# With AI_LIVE_CALLS=true you can still switch off ONE capability at a time —
# e.g. draft real text but stop paying ~$0.067 an image. (These can only turn
# things OFF: a `true` here cannot override AI_LIVE_CALLS=false.)
# AI_LIVE_TEXT=true
# AI_LIVE_IMAGES=false
# AI_LIVE_TRANSCRIBE=true
# AI_LIVE_PLACES=true

# Which text model, when live. The model FOLLOWS the provider (see .env.example),
# so this line alone is a complete, correct switch:
# AI_TEXT_PROVIDER=anthropic     # anthropic | openai | fake
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
